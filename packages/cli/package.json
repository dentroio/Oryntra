  },
  "dependencies": {
    "@oryntra/core": "0.1.0",
    "@oryntra/server": "0.1.0",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "^5.8.0"
